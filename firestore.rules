rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function profile() {
      return get(userPath()).data;
    }

    function hasProfile() {
      return signedIn() && exists(userPath());
    }

    function isActive() {
      return hasProfile() && profile().status == 'active';
    }

    function isController() {
      return isActive() && profile().role == 'controller';
    }

    function isOperator() {
      return isActive() && profile().role == 'operator';
    }

    function sameOrg(organizationId) {
      return isActive() && profile().organizationId == organizationId;
    }

    function sameOrgResource() {
      return sameOrg(resource.data.organizationId);
    }

    function sameOrgRequest() {
      return sameOrg(request.resource.data.organizationId);
    }

    function validOperationStatus(status) {
      return status in ['open', 'paused', 'closed'];
    }

    function validCycleStatus(status) {
      return status in ['pending', 'under_review', 'won', 'lost', 'canceled'];
    }

    match /organizations/{organizationId} {
      allow read: if sameOrg(organizationId);
      allow create: if signedIn()
        && request.resource.data.ownerUserId == request.auth.uid;
      allow update: if isController() && sameOrg(organizationId);
      allow delete: if false;
    }

    match /system/bootstrap {
      allow read: if true;
      allow create: if signedIn()
        && !exists(/databases/$(database)/documents/system/bootstrap)
        && request.resource.data.hasFirstAdmin == true
        && request.resource.data.controllerUserId == request.auth.uid
        && request.resource.data.createdAt == request.time;
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow read: if signedIn() && (
        userId == request.auth.uid ||
        (isController() && sameOrgResource())
      );

      allow create: if signedIn() && (
        (userId == request.auth.uid && (
          (!exists(/databases/$(database)/documents/system/bootstrap)
            && request.resource.data.role == 'controller'
            && request.resource.data.status == 'active'
            && request.resource.data.createdBy == request.auth.uid) ||
          (request.resource.data.role == 'operator'
            && request.resource.data.status == 'active'
            && request.resource.data.acceptedInviteId is string
            && get(/databases/$(database)/documents/invites/$(request.resource.data.acceptedInviteId)).data.status == 'pending'
            && get(/databases/$(database)/documents/invites/$(request.resource.data.acceptedInviteId)).data.email == request.auth.token.email
            && get(/databases/$(database)/documents/invites/$(request.resource.data.acceptedInviteId)).data.organizationId == request.resource.data.organizationId)
        )) ||
        (isController() && sameOrgRequest())
      );

      allow update: if signedIn() && (
        (userId == request.auth.uid
          && resource.data.organizationId == request.resource.data.organizationId
          && resource.data.role == request.resource.data.role
          && resource.data.status == request.resource.data.status) ||
        (isController() && sameOrgResource() && sameOrgRequest())
      );

      allow delete: if false;
    }

    match /invites/{inviteId} {
      allow read: if isController() && sameOrgResource();
      allow get: if signedIn()
          && resource.data.status == 'pending'
          && resource.data.email == request.auth.token.email;
      allow create: if isController()
        && sameOrgRequest()
        && request.resource.data.status == 'pending';
      allow update: if (isController() && sameOrgResource() && sameOrgRequest()) ||
        (signedIn()
          && resource.data.status == 'pending'
          && resource.data.email == request.auth.token.email
          && request.resource.data.organizationId == resource.data.organizationId
          && request.resource.data.email == resource.data.email
          && request.resource.data.role == resource.data.role
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.status == 'accepted'
          && request.resource.data.acceptedBy == request.auth.uid);
      allow delete: if false;
    }

    match /bettingHouses/{houseId} {
      allow read: if sameOrgResource();
      allow create: if isController() && sameOrgRequest();
      allow update: if isController() && sameOrgResource() && sameOrgRequest();
      allow delete: if false;
    }

    match /operations/{operationId} {
      allow read: if sameOrgResource()
        && (isController() || resource.data.operatorId == request.auth.uid);
      allow create: if sameOrgRequest()
        && validOperationStatus(request.resource.data.status)
        && get(/databases/$(database)/documents/bettingHouses/$(request.resource.data.bettingHouseId)).data.status == 'active'
        && (isController() || request.resource.data.operatorId == request.auth.uid);
      allow update: if sameOrgResource()
        && sameOrgRequest()
        && validOperationStatus(request.resource.data.status)
        && (isController() || resource.data.operatorId == request.auth.uid);
      allow delete: if false;
    }

    match /cycles/{cycleId} {
      allow read: if sameOrgResource()
        && (isController() || resource.data.operatorId == request.auth.uid);
      allow create: if sameOrgRequest()
        && request.resource.data.operatorId == request.auth.uid
        && validCycleStatus(request.resource.data.status)
        && request.resource.data.proofRequired == true
        && request.resource.data.proofCount > 0
        && get(/databases/$(database)/documents/operations/$(request.resource.data.operationId)).data.status == 'open';
      allow update: if sameOrgResource()
        && sameOrgRequest()
        && validCycleStatus(request.resource.data.status)
        && request.resource.data.proofCount >= resource.data.proofCount
        && (isController() || resource.data.operatorId == request.auth.uid);
      allow delete: if false;
    }

    match /cycleProofs/{proofId} {
      allow read: if sameOrgResource()
        && (isController() || resource.data.operatorId == request.auth.uid);
      allow create: if sameOrgRequest()
        && request.resource.data.uploadedBy == request.auth.uid
        && request.resource.data.operatorId == request.auth.uid;
      allow update, delete: if false;
    }

    match /goals/{goalId} {
      allow read: if sameOrgResource()
        && (isController() || resource.data.operatorId == request.auth.uid || resource.data.scope == 'organization');
      allow create: if isController() && sameOrgRequest();
      allow update: if isController() && sameOrgResource() && sameOrgRequest();
      allow delete: if false;
    }

    match /auditLogs/{auditLogId} {
      allow read: if isController() && sameOrgResource();
      allow create: if sameOrgRequest()
        && request.resource.data.actorUserId == request.auth.uid
        && request.resource.data.createdAt == request.time;
      allow update, delete: if false;
    }
  }
}
